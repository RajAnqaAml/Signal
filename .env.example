# Copy this file to .env and fill in your real values. .env is gitignored.
#
# Supabase: get these from your project's Settings → API page
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...     # safe to expose to browser (read-only via RLS)
SUPABASE_SERVICE_KEY=eyJhbGciOi...  # KEEP SECRET — recorder + backfill use this

# ntfy.sh push notifications. Pick an unguessable string — anyone with this
# topic name can read AND send your alerts. Treat it like a password.
NTFY_TOPIC=nse-signals-pick-a-random-12-char-suffix

# Optional:
# NTFY_SERVER=https://ntfy.sh    # default; override if self-hosting ntfy
# PYTHONIOENCODING=utf-8
